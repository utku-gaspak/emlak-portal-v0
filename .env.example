# --- AUTHENTICATION (ADMIN) ---
# Admin paneline giriş için kullanıcı adı ve şifre
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# --- NEXTAUTH ---
# openssl rand -base64 32 ile üretilen gizli anahtar
NEXTAUTH_SECRET=your_nextauth_secret_here
# Canlıda: https://siteniz.vercel.app | Yerelde: http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# --- CLOUDINARY (MEDIA STORAGE) ---
# Cloudinary Dashboard -> Product Environment Settings
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- SUPABASE (DATABASE) ---
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
# DİKKAT: Sadece server-side tarafta kullanılmalı (NEXT_PUBLIC_ eklemeyin)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- CONTACT & SOCIAL MEDIA (NEXT_PUBLIC_ REQUIRED FOR UI) ---
# Başına 90 ekleyerek yazın (Örn: 905XXXXXXXXX)
NEXT_PUBLIC_CONTACT_PHONE=905000000000
NEXT_PUBLIC_CONTACT_EMAIL=info@yourdomain.com
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/yourprofile
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/yourpage